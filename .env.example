# Copy to .env for `docker compose up`. All values below are safe local-dev defaults.

POSTGRES_DB=leads
POSTGRES_USER=leads
POSTGRES_PASSWORD=leads

JWT_SECRET=change-me-to-a-long-random-string
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_PASSWORD=changeme123

# Shared invite code required to register additional attorney accounts.
ATTORNEY_SIGNUP_CODE=change-me-invite-code

# Leave SMTP_HOST empty to have the backend log emails to ./emails instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
