# Copy to .env and adjust as needed. All values below are safe local-dev defaults.

# Storage
DATABASE_URL=sqlite:///./app.db
UPLOAD_DIR=./uploads
MAX_RESUME_SIZE_BYTES=5242880

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=720

# Seeded attorney login (used for the internal UI)
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_PASSWORD=changeme123

# Shared invite code required to register additional attorney accounts via
# POST /api/auth/register or the /register page.
ATTORNEY_SIGNUP_CODE=change-me-invite-code

# Email (SMTP). Leave SMTP_HOST unset to fall back to logging emails under ./emails/
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
FALLBACK_EMAIL_DIR=./emails

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
